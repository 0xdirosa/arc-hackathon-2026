# LLM (OpenRouter recommended — supports OpenAI, Claude, Gemini)
# OPENROUTER_API_KEY=sk-or-v1-...
# LLM_MODEL=openai/gpt-4o

# OpenAI (fallback if OpenRouter not set)
# OPENAI_API_KEY=sk-...

# Prediction Market contract (deployed on Arc testnet)
PREDICTION_MARKET_CONTRACT=0x...

# Agent Stack wallet (created via Circle CLI login)
AGENT_STACK_ADDRESS=0x...
AGENT_STACK_ID=0

# Circle Developer-Controlled Wallets (optional — for DCW SDK path)
# CIRCLE_API_KEY=PREFIX:ID:SECRET
# CIRCLE_ENTITY_SECRET=...
# AGENT_WALLET_ID=wallet_...
# AGENT_WALLET_ADDRESS=0x...

# Deployer key (for contract deployment — testnet only)
# DEPLOYER_PRIVATE_KEY=0x...

# Arc Testnet RPC
# RPC=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_TOKEN
